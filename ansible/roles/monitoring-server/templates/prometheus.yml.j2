global:
  scrape_interval: 15s
  evaluation_interval: 15s

rule_files:
  - /etc/prometheus/alert-rules.yml

alerting:
  alertmanagers:
    - static_configs:
        - targets:
            - alertmanager:9093

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets:
          - localhost:9090

  - job_name: node
    static_configs:
      - targets:
          - {{ groups.staging[0] }}:{{ monitoring_node_exporter_port }}
        labels:
          env: staging
      - targets:
          - {{ groups.production[0] }}:{{ monitoring_node_exporter_port }}
        labels:
          env: production
      - targets:
          - node-exporter:9100
        labels:
          env: internal

  - job_name: cadvisor
    static_configs:
      - targets:
          - {{ groups.staging[0] }}:{{ monitoring_cadvisor_port }}
        labels:
          env: staging
      - targets:
          - {{ groups.production[0] }}:{{ monitoring_cadvisor_port }}
        labels:
          env: production
      - targets:
          - cadvisor:8080
        labels:
          env: internal

  # redis_exporter on each app VM, configured by monitoring-client to check
  # LLEN of bull:*:wait keys. Surfaces queue depth as redis_key_size{key="..."}.
  - job_name: redis_bullmq
    static_configs:
      - targets:
          - {{ groups.staging[0] }}:{{ monitoring_redis_exporter_port }}
        labels:
          env: staging
          service: backend
      - targets:
          - {{ groups.production[0] }}:{{ monitoring_redis_exporter_port }}
        labels:
          env: production
          service: backend

{% for probe in monitoring_http_probes %}
  - job_name: blackbox_{{ probe.name }}
    metrics_path: /probe
    params:
      module:
        - {{ probe.module }}
    static_configs:
      - targets:
          - {{ probe.target }}
        labels:
          env: {{ probe.env }}
          service: {{ probe.service }}
          probe: {{ probe.name }}
    relabel_configs:
      - source_labels:
          - __address__
        target_label: __param_target
      - source_labels:
          - __param_target
        target_label: instance
      - target_label: __address__
        replacement: blackbox-exporter:9115

{% endfor %}
