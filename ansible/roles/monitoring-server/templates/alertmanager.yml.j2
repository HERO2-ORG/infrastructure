route:
  group_by:
    - env
    - alertname
    - instance
  group_wait: 30s
  group_interval: 10m
  repeat_interval: 12h
  receiver: drop
  routes:
    - receiver: slack-alerts
      matchers:
        - severity="critical"

receivers:
  - name: drop
  - name: slack-alerts
    slack_configs:
      - api_url: "{{ monitoring_slack_webhook_url }}"
        channel: "{{ monitoring_slack_channel }}"
        username: Hero2 Monitoring
        send_resolved: false
        icon_emoji: '{% raw %}{{ if eq .Status "firing" }}:rotating_light:{{ else }}:white_check_mark:{{ end }}{% endraw %}'
        color: '{% raw %}{{ if eq .Status "firing" }}danger{{ else }}good{{ end }}{% endraw %}'
        title: '{% raw %}[{{ .Status | toUpper }}{{ if eq .Status "firing" }}:{{ .Alerts.Firing | len }}{{ end }}] {{ .CommonLabels.alertname }}{{ with .CommonLabels.env }} · {{ . }}{{ end }}{% endraw %}'
        text: |-
          {% raw %}{{ range .Alerts -}}
          *{{ .Annotations.summary }}*
          {{ .Annotations.description }}
          {{- with .Labels.service }}
          service: `{{ . }}` · {{ end }}severity: `{{ .Labels.severity }}`

          {{ end -}}{% endraw %}
