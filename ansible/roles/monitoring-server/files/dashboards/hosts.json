{
  "annotations": { "list": [] },
  "description": "Per-host CPU, memory, disk, network and load. Mirrors the host_health alerts. Thresholds drawn match alert firing levels.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "description": "CPU averaged across all cores (1 - idle %). Identical reading whether all cores are at 60% or some are 100% and others idle — use the 'Max core' panel next to it to distinguish.",
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "orange", "value": 70 },
                  { "color": "red", "value": 90 }
                ]
              },
              "unit": "percent",
              "min": 0,
              "max": 100
            },
            "overrides": []
          },
          "gridPos": { "h": 7, "w": 4, "x": 0, "y": 1 },
          "id": 1,
          "options": {
            "orientation": "auto",
            "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
            "showThresholdLabels": false,
            "showThresholdMarkers": true
          },
          "pluginVersion": "13.0.1",
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "prometheus" },
              "expr": "100 - (avg by (env) (rate(node_cpu_seconds_total{mode=\"idle\",env=\"$env\"}[5m])) * 100)",
              "instant": true,
              "legendFormat": "Avg",
              "refId": "A"
            }
          ],
          "title": "Avg CPU",
          "type": "gauge"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "description": "Busiest single core (1 - max idle). If this is 100% while Avg CPU is low, one core is saturated — usually a single-threaded process pinning a core.",
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "orange", "value": 80 },
                  { "color": "red", "value": 95 }
                ]
              },
              "unit": "percent",
              "min": 0,
              "max": 100
            },
            "overrides": []
          },
          "gridPos": { "h": 7, "w": 4, "x": 4, "y": 1 },
          "id": 6,
          "options": {
            "orientation": "auto",
            "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
            "showThresholdLabels": false,
            "showThresholdMarkers": true
          },
          "pluginVersion": "13.0.1",
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "prometheus" },
              "expr": "100 - (min by (env) (rate(node_cpu_seconds_total{mode=\"idle\",env=\"$env\"}[5m])) * 100)",
              "instant": true,
              "legendFormat": "Max core",
              "refId": "A"
            }
          ],
          "title": "Max core",
          "type": "gauge"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "description": "1 - (MemAvailable / MemTotal). MemoryExhaustionCritical fires when available < 5% for 10m.",
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "orange", "value": 80 },
                  { "color": "red", "value": 95 }
                ]
              },
              "unit": "percent",
              "min": 0,
              "max": 100
            },
            "overrides": []
          },
          "gridPos": { "h": 7, "w": 4, "x": 8, "y": 1 },
          "id": 2,
          "options": {
            "orientation": "auto",
            "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
            "showThresholdLabels": false,
            "showThresholdMarkers": true
          },
          "pluginVersion": "13.0.1",
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "prometheus" },
              "expr": "(1 - (sum by (env) (node_memory_MemAvailable_bytes{env=\"$env\"}) / sum by (env) (node_memory_MemTotal_bytes{env=\"$env\"}))) * 100",
              "instant": true,
              "legendFormat": "Memory",
              "refId": "A"
            }
          ],
          "title": "Memory",
          "type": "gauge"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "description": "Filesystem fill % for /. DiskUsageCritical fires above 90% for 10m.",
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "orange", "value": 70 },
                  { "color": "red", "value": 90 }
                ]
              },
              "unit": "percent",
              "min": 0,
              "max": 100
            },
            "overrides": []
          },
          "gridPos": { "h": 7, "w": 4, "x": 12, "y": 1 },
          "id": 3,
          "options": {
            "orientation": "auto",
            "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
            "showThresholdLabels": false,
            "showThresholdMarkers": true
          },
          "pluginVersion": "13.0.1",
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "prometheus" },
              "expr": "(1 - (node_filesystem_avail_bytes{env=\"$env\",fstype!=\"tmpfs\",mountpoint=\"/\"} / node_filesystem_size_bytes{env=\"$env\",fstype!=\"tmpfs\",mountpoint=\"/\"})) * 100",
              "instant": true,
              "legendFormat": "/",
              "refId": "A"
            }
          ],
          "title": "Disk /",
          "type": "gauge"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "description": "Disk usage broken down by /srv/stack/* and /srv/data/* directory plus 'other' (everything outside /srv: system, docker images, container writable layers). Powered by the node-exporter textfile collector. Refreshes every 5 minutes.",
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "custom": {
                "align": "auto",
                "displayMode": "lcd-gauge",
                "filterable": false
              },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "blue", "value": null }
                ]
              },
              "unit": "bytes"
            },
            "overrides": [
              {
                "matcher": { "id": "byName", "options": "Directory" },
                "properties": [{ "id": "custom.displayMode", "value": "auto" }]
              }
            ]
          },
          "gridPos": { "h": 7, "w": 8, "x": 16, "y": 1 },
          "id": 7,
          "options": {
            "cellHeight": "sm",
            "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
            "showHeader": true,
            "sortBy": [{ "desc": true, "displayName": "Size" }]
          },
          "pluginVersion": "13.0.1",
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "prometheus" },
              "expr": "srv_directory_used_bytes{env=\"$env\"} or label_replace((node_filesystem_size_bytes{env=\"$env\",mountpoint=\"/\",fstype!=\"tmpfs\"} - node_filesystem_avail_bytes{env=\"$env\",mountpoint=\"/\",fstype!=\"tmpfs\"} - on() (sum(srv_directory_used_bytes{env=\"$env\"}) or on() vector(0))), \"name\", \"other\", \"\", \"\")",
              "format": "table",
              "instant": true,
              "refId": "A"
            }
          ],
          "title": "Disk breakdown",
          "transformations": [
            {
              "id": "organize",
              "options": {
                "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true, "env": true, "path": true, "mountpoint": true, "fstype": true, "device": true, "category": true },
                "renameByName": { "name": "Directory", "Value": "Size" }
              }
            }
          ],
          "type": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "description": "CPU usage broken down by what the kernel was doing: user (your apps), system (kernel/syscalls), iowait (blocked on disk/net), steal (hypervisor took your cycles). Useful for diagnosing why CPU is high.",
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "palette-classic" },
              "custom": {
                "drawStyle": "line",
                "fillOpacity": 30,
                "lineInterpolation": "linear",
                "lineWidth": 1,
                "showPoints": "never",
                "spanNulls": false,
                "stacking": { "mode": "normal", "group": "A" }
              },
              "unit": "percent",
              "min": 0,
              "max": 100
            },
            "overrides": []
          },
          "gridPos": { "h": 7, "w": 8, "x": 0, "y": 8 },
          "id": 8,
          "options": {
            "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom", "showLegend": true },
            "tooltip": { "mode": "multi", "sort": "desc" }
          },
          "pluginVersion": "13.0.1",
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "prometheus" },
              "expr": "avg by (mode) (rate(node_cpu_seconds_total{env=\"$env\",mode!=\"idle\"}[5m])) * 100",
              "legendFormat": "{{mode}}",
              "refId": "A"
            }
          ],
          "title": "CPU by mode",
          "type": "timeseries"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "description": "Per-interface RX/TX (bytes/sec). No alert; host-level signal for correlating with latency or saturation. Request-rate metrics belong in a service dashboard.",
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "palette-classic" },
              "custom": {
                "drawStyle": "line",
                "fillOpacity": 10,
                "lineInterpolation": "linear",
                "lineWidth": 1,
                "showPoints": "never",
                "spanNulls": false
              },
              "unit": "Bps"
            },
            "overrides": [
              {
                "matcher": { "id": "byRegexp", "options": "/tx .*/" },
                "properties": [{ "id": "custom.transform", "value": "negative-Y" }]
              }
            ]
          },
          "gridPos": { "h": 7, "w": 8, "x": 8, "y": 8 },
          "id": 4,
          "options": {
            "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
            "tooltip": { "mode": "multi", "sort": "desc" }
          },
          "pluginVersion": "13.0.1",
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "prometheus" },
              "expr": "rate(node_network_receive_bytes_total{env=\"$env\",device!~\"lo|veth.*|docker.*|br-.*\"}[5m])",
              "legendFormat": "rx {{device}}",
              "refId": "A"
            },
            {
              "datasource": { "type": "prometheus", "uid": "prometheus" },
              "expr": "rate(node_network_transmit_bytes_total{env=\"$env\",device!~\"lo|veth.*|docker.*|br-.*\"}[5m])",
              "legendFormat": "tx {{device}}",
              "refId": "B"
            }
          ],
          "title": "Network throughput",
          "type": "timeseries"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "description": "Number of processes either running on a CPU or waiting (for CPU or for blocking I/O) over 1/5/15-minute windows. Below the dashed red line (1.5× cores) the host has slack. Sustained above means processes are queueing for CPU or blocked on I/O. HostSaturationCritical fires when load15 exceeds the red line AND CPU >90% for 15m.",
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "palette-classic" },
              "custom": {
                "drawStyle": "line",
                "fillOpacity": 5,
                "lineInterpolation": "linear",
                "lineWidth": 1,
                "showPoints": "never",
                "spanNulls": false
              }
            },
            "overrides": [
              {
                "matcher": { "id": "byName", "options": "1.5x cores" },
                "properties": [
                  { "id": "custom.lineStyle", "value": { "fill": "dash" } },
                  { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
                ]
              }
            ]
          },
          "gridPos": { "h": 7, "w": 8, "x": 16, "y": 8 },
          "id": 5,
          "options": {
            "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom", "showLegend": true },
            "tooltip": { "mode": "multi", "sort": "desc" }
          },
          "pluginVersion": "13.0.1",
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "prometheus" },
              "expr": "node_load1{env=\"$env\"}",
              "legendFormat": "load1",
              "refId": "A"
            },
            {
              "datasource": { "type": "prometheus", "uid": "prometheus" },
              "expr": "node_load5{env=\"$env\"}",
              "legendFormat": "load5",
              "refId": "B"
            },
            {
              "datasource": { "type": "prometheus", "uid": "prometheus" },
              "expr": "node_load15{env=\"$env\"}",
              "legendFormat": "load15",
              "refId": "C"
            },
            {
              "datasource": { "type": "prometheus", "uid": "prometheus" },
              "expr": "count(node_cpu_seconds_total{mode=\"idle\",env=\"$env\"}) * 1.5",
              "legendFormat": "1.5x cores",
              "refId": "D"
            }
          ],
          "title": "Load (running + waiting processes)",
          "type": "timeseries"
        }
      ],
      "repeat": "env",
      "repeatDirection": "h",
      "title": "$env",
      "type": "row"
    }
  ],
  "preload": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["hero2", "host"],
  "templating": {
    "list": [
      {
        "current": {
          "selected": true,
          "text": ["production", "staging", "internal"],
          "value": ["production", "staging", "internal"]
        },
        "description": "Environments to show, in display order.",
        "includeAll": false,
        "label": "Environment",
        "multi": true,
        "name": "env",
        "options": [
          { "selected": true, "text": "production", "value": "production" },
          { "selected": true, "text": "staging", "value": "staging" },
          { "selected": true, "text": "internal", "value": "internal" }
        ],
        "query": "production,staging,internal",
        "queryValue": "",
        "skipUrlSync": false,
        "type": "custom"
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Hosts",
  "uid": "hosts",
  "version": 3,
  "weekStart": ""
}
