{
  "annotations": { "list": [] },
  "description": "Per-host CPU, memory, disk, network and load. Mirrors the host_health alerts (ServerDown, DiskUsageCritical, DiskWillFillSoon, MemoryExhaustionCritical, HostSaturationCritical). Thresholds drawn match alert firing levels.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "description": "1 - idle %. HostSaturationCritical fires when >90% sustained with load>1.5x cores for 15m.",
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "orange", "value": 70 },
                  { "color": "red", "value": 90 }
                ]
              },
              "unit": "percent",
              "min": 0,
              "max": 100
            },
            "overrides": []
          },
          "gridPos": { "h": 7, "w": 6, "x": 0, "y": 1 },
          "id": 1,
          "options": {
            "orientation": "auto",
            "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
            "showThresholdLabels": false,
            "showThresholdMarkers": true
          },
          "pluginVersion": "13.0.1",
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "prometheus" },
              "expr": "100 - (avg by (env) (rate(node_cpu_seconds_total{mode=\"idle\",env=\"$env\"}[5m])) * 100)",
              "instant": true,
              "legendFormat": "CPU",
              "refId": "A"
            }
          ],
          "title": "CPU",
          "type": "gauge"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "description": "1 - (MemAvailable / MemTotal). MemoryExhaustionCritical fires when available < 5% for 10m.",
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "orange", "value": 80 },
                  { "color": "red", "value": 95 }
                ]
              },
              "unit": "percent",
              "min": 0,
              "max": 100
            },
            "overrides": []
          },
          "gridPos": { "h": 7, "w": 6, "x": 6, "y": 1 },
          "id": 2,
          "options": {
            "orientation": "auto",
            "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
            "showThresholdLabels": false,
            "showThresholdMarkers": true
          },
          "pluginVersion": "13.0.1",
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "prometheus" },
              "expr": "(1 - (sum by (env) (node_memory_MemAvailable_bytes{env=\"$env\"}) / sum by (env) (node_memory_MemTotal_bytes{env=\"$env\"}))) * 100",
              "instant": true,
              "legendFormat": "Memory",
              "refId": "A"
            }
          ],
          "title": "Memory",
          "type": "gauge"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "description": "Per-mountpoint usage for / and /srv*. DiskUsageCritical fires above 90% for 10m; DiskWillFillSoon fires if the 6h trend predicts full within 24h.",
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "custom": {
                "align": "auto",
                "displayMode": "lcd-gauge",
                "filterable": false
              },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "orange", "value": 70 },
                  { "color": "red", "value": 90 }
                ]
              },
              "unit": "percent",
              "min": 0,
              "max": 100
            },
            "overrides": [
              {
                "matcher": { "id": "byName", "options": "mountpoint" },
                "properties": [{ "id": "custom.displayMode", "value": "auto" }]
              }
            ]
          },
          "gridPos": { "h": 7, "w": 12, "x": 12, "y": 1 },
          "id": 3,
          "options": {
            "cellHeight": "sm",
            "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
            "showHeader": true,
            "sortBy": [{ "desc": true, "displayName": "Used %" }]
          },
          "pluginVersion": "13.0.1",
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "prometheus" },
              "expr": "(1 - (node_filesystem_avail_bytes{env=\"$env\",fstype!=\"tmpfs\",mountpoint=~\"/|/srv.*\"} / node_filesystem_size_bytes{env=\"$env\",fstype!=\"tmpfs\",mountpoint=~\"/|/srv.*\"})) * 100",
              "format": "table",
              "instant": true,
              "refId": "A"
            }
          ],
          "title": "Disk usage",
          "transformations": [
            {
              "id": "organize",
              "options": {
                "excludeByName": { "Time": true, "__name__": true, "job": true, "env": true, "instance": true, "fstype": true, "device": true },
                "renameByName": { "mountpoint": "Mount", "Value": "Used %" }
              }
            }
          ],
          "type": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "description": "Per-interface RX/TX. No alert; useful for correlating with latency or saturation.",
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "palette-classic" },
              "custom": {
                "drawStyle": "line",
                "fillOpacity": 10,
                "lineInterpolation": "linear",
                "lineWidth": 1,
                "showPoints": "never",
                "spanNulls": false
              },
              "unit": "Bps"
            },
            "overrides": [
              {
                "matcher": { "id": "byRegexp", "options": "/tx .*/" },
                "properties": [{ "id": "custom.transform", "value": "negative-Y" }]
              }
            ]
          },
          "gridPos": { "h": 7, "w": 12, "x": 0, "y": 8 },
          "id": 4,
          "options": {
            "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
            "tooltip": { "mode": "multi", "sort": "desc" }
          },
          "pluginVersion": "13.0.1",
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "prometheus" },
              "expr": "rate(node_network_receive_bytes_total{env=\"$env\",device!~\"lo|veth.*|docker.*|br-.*\"}[5m])",
              "legendFormat": "rx {{device}}",
              "refId": "A"
            },
            {
              "datasource": { "type": "prometheus", "uid": "prometheus" },
              "expr": "rate(node_network_transmit_bytes_total{env=\"$env\",device!~\"lo|veth.*|docker.*|br-.*\"}[5m])",
              "legendFormat": "tx {{device}}",
              "refId": "B"
            }
          ],
          "title": "Network throughput",
          "type": "timeseries"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "description": "load1/5/15 versus 1.5x CPU count. HostSaturationCritical fires when load15/cores > 1.5 with CPU >90% for 15m.",
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "palette-classic" },
              "custom": {
                "drawStyle": "line",
                "fillOpacity": 5,
                "lineInterpolation": "linear",
                "lineWidth": 1,
                "showPoints": "never",
                "spanNulls": false
              }
            },
            "overrides": [
              {
                "matcher": { "id": "byName", "options": "1.5x cores" },
                "properties": [
                  { "id": "custom.lineStyle", "value": { "fill": "dash" } },
                  { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
                ]
              }
            ]
          },
          "gridPos": { "h": 7, "w": 12, "x": 12, "y": 8 },
          "id": 5,
          "options": {
            "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom", "showLegend": true },
            "tooltip": { "mode": "multi", "sort": "desc" }
          },
          "pluginVersion": "13.0.1",
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "prometheus" },
              "expr": "node_load1{env=\"$env\"}",
              "legendFormat": "load1",
              "refId": "A"
            },
            {
              "datasource": { "type": "prometheus", "uid": "prometheus" },
              "expr": "node_load5{env=\"$env\"}",
              "legendFormat": "load5",
              "refId": "B"
            },
            {
              "datasource": { "type": "prometheus", "uid": "prometheus" },
              "expr": "node_load15{env=\"$env\"}",
              "legendFormat": "load15",
              "refId": "C"
            },
            {
              "datasource": { "type": "prometheus", "uid": "prometheus" },
              "expr": "count(node_cpu_seconds_total{mode=\"idle\",env=\"$env\"}) * 1.5",
              "legendFormat": "1.5x cores",
              "refId": "D"
            }
          ],
          "title": "Load average",
          "type": "timeseries"
        }
      ],
      "repeat": "env",
      "repeatDirection": "h",
      "title": "$env",
      "type": "row"
    }
  ],
  "preload": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["hero2", "host"],
  "templating": {
    "list": [
      {
        "current": {
          "selected": true,
          "text": ["production", "staging", "internal"],
          "value": ["production", "staging", "internal"]
        },
        "description": "Environments to show, in display order.",
        "includeAll": false,
        "label": "Environment",
        "multi": true,
        "name": "env",
        "options": [
          { "selected": true, "text": "production", "value": "production" },
          { "selected": true, "text": "staging", "value": "staging" },
          { "selected": true, "text": "internal", "value": "internal" }
        ],
        "query": "production,staging,internal",
        "queryValue": "",
        "skipUrlSync": false,
        "type": "custom"
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Hosts",
  "uid": "hosts",
  "version": 2,
  "weekStart": ""
}
